{
  "name": "site-to-figma-plugin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:plugin && npm run build:service",
    "build:plugin": "node ./scripts/build-plugin.mjs",
    "build:service": "tsc -p tsconfig.service.json",
    "dev:service": "npm run build:service && node ./service/dist/service/index.js",
    "watch:service": "tsc -p tsconfig.service.json --watch",
    "start:service": "node ./service/dist/service/index.js",
    "install:browser": "playwright install chromium"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "playwright": "^1.55.0"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.117.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.6.0",
    "esbuild": "^0.25.10",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
